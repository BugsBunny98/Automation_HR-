=======
# Test credentials for API authentication (optional)
# Used by tests/api/apiClient.ts for backend setup/teardown
TEST_EMAIL=
TEST_PASSWORD=

# Pre-configured API auth token (optional, for CI environments)
# If set, apiClient will use this token instead of authenticating
API_AUTH_TOKEN=

# ==============================================================================
# Test Configuration
# ==============================================================================

# Skip the authentication setup project (useful when running specific tests)
# Set to '1' to skip, unset or '0' to run auth setup
# SKIP_AUTH_SETUP=0

# Reuse existing auth state if fresh (less than 30 minutes old)
# Set to '1' to enable reuse, useful for local development
# REUSE_AUTH_STATE=0

# Enable regression for Egypt 015 sample (1555558380)
# Only set to '1' when staging accepts that MSISDN
# E2E_ENABLE_EGYPT_015=0

# ==============================================================================
# Docker Configuration
# ==============================================================================

# Test suite to run in Docker container
# Options: e2e, smoke, regression, onboarding
TEST_SUITE=e2e
