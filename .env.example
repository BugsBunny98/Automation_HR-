# ==============================================================================
# Playwright E2E Test Configuration
# ==============================================================================
# Copy to `.env` and adjust. Playwright loads `.env` from the project root
# via `playwright.config.ts`. Never commit `.env` to version control.
# ==============================================================================

# ==============================================================================
# Application URLs
# ==============================================================================

# Origin only (no trailing slash). Used as Playwright `baseURL` and to derive
# login/home URLs in tests.
E2E_BASE_URL=https://staging.bluworks.io

# API base URL for API-assisted test setup/cleanup
# TODO: confirm exact staging API base URL
API_BASE_URL=https://api.staging.bluworks.io

# ==============================================================================
# Test Credentials
# ==============================================================================

# Override staging OTP used for happy-path tests (default: 8182)
# E2E_STAGING_OTP=8182

# Wrong OTP for negative tests (default: 9090)
# E2E_INVALID_OTP=9090

# Test account credentials for auth setup (tests/setup/global.setup.ts)
TEST_EMAIL=test@example.com
TEST_PASSWORD=changeme

# Pre-configured API auth token (optional — overrides email/password in API client)
# API_AUTH_TOKEN=

# ==============================================================================
# Test Execution Flags
# ==============================================================================

# Skip the authentication setup project (set to '1' to bypass global.setup.ts)
# SKIP_AUTH_SETUP=0

# Reuse existing auth state if fresh (less than 30 minutes old)
# REUSE_AUTH_STATE=0

# Enable regression for Egypt 015 sample (1555558380)
# Only set to '1' when staging accepts that MSISDN
# E2E_ENABLE_EGYPT_015=0

# ==============================================================================
# Notes
# ==============================================================================
#
# UAE phone (507021238) and OTP (2050) are hardcoded in tests/data/loginData.ts.
# E2E_UAE_PHONE is no longer used.
#
# For CI/CD:
#   Store secrets in GitHub → Settings → Secrets → Actions (not in .env files).
#   Required secrets: APP_BASE_URL, STAGING_OTP, TEST_EMAIL, TEST_PASSWORD
#
# For local development:
#   cp .env.example .env   then fill in real values
#   npm run test:smoke      quick local validation
#   npm run docker:smoke    containerised smoke run
