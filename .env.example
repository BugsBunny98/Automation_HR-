# Copy to `.env` and adjust. Playwright loads `.env` from the project root via `playwright.config.ts`.

# Origin only (no trailing slash). Used as Playwright `baseURL` and to derive login/home URLs in tests.
E2E_BASE_URL=https://staging.bluworks.io

# Optional: override staging OTP used for happy-path tests (default: 8182).
# E2E_STAGING_OTP=8182

# Optional: wrong OTP for negative tests (default: 9090).
# E2E_INVALID_OTP=9090

# Required for `valid UAE login` smoke: a real UAE mobile that receives OTP on staging (9 digits, no +971).
# If unset, that test is skipped so `npm run test:smoke` stays green with Egypt-only data.
# E2E_UAE_PHONE=501234567

# Optional: enable regression for Egypt 015 sample (1555558380) when staging accepts that MSISDN.
# E2E_ENABLE_EGYPT_015=1
