# ==============================================================================
# Dependencies
# ==============================================================================
node_modules/

# ==============================================================================
# Playwright Artifacts
# ==============================================================================
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Auth state (contains sensitive session data)
/playwright/.auth/user.json
/playwright/.auth/*.json
!playwright/.auth/.gitkeep

# ==============================================================================
# Environment & Secrets
# ==============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# ==============================================================================
# IDE & Editor
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.claude/
.playwright-cli/

# ==============================================================================
# OS Files
# ==============================================================================
.DS_Store
Thumbs.db

# ==============================================================================
# Build Artifacts
# ==============================================================================
dist/
build/
*.tsbuildinfo

# ==============================================================================
# Logs
# ==============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================================
# Docker
# ==============================================================================
# Docker build cache (if using local builds)
.docker/

# Temporary files from Docker runs
tmp/
temp/

# ==============================================================================
# Coverage & Reports
# ==============================================================================
coverage/
*.lcov

# ==============================================================================
# Exports & Generated Files
# ==============================================================================
/docs/exports/*.xlsx
